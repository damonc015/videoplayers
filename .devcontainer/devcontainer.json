// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/javascript-node
{
	"name": "proto",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	// uncomment this section if you want to bind mount your aws credentials
	// "mounts": [
	// 	"source=${localEnv:HOME}${localEnv:USERPROFILE}/.aws,target=/home/vscode/.aws,type=bind,readonly"
	// ]

	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "none", // setting node version from .nvmrc
			"nodeGypDependencies": true
		},
		"ghcr.io/devcontainers/features/aws-cli:1": {}
	},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [
		3000
	],

	// Use 'updateContentCommand' to install dependencies before the UI connects
	"updateContentCommand": "bash -i -c 'nvm install && nvm use && npm install'",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"editorconfig.editorconfig",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"bradlc.vscode-tailwindcss"
			]
		}
	}
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
